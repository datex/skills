    "DataSources": [
        {
            "Name": "Datasource",
            "ConnectionProperties": {
                "DataProvider": "JSONEMBED",
                "ConnectString": "jsondata={}"
            }
        }
    ],
    "DataSets": [
        {
            "Name": "ds_sales",
            "Fields": [
                {
                    "Name": "StoreName",
                    "DataField": "StoreName"
                },
                {
                    "Name": "SaleDate",
                    "DataField": "SaleDate[Date|YYYY-MM-DDTHH:mm:ss.fffffff]"

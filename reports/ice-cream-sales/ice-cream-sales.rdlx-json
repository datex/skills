                },
                {
                    "Name": "Trend",
                    "DataField": "Trend"
                },
                {
                    "Name": "ReportPeriod",
                    "DataField": "ReportPeriod"
                }
            ],
            "Query": {
                "DataSourceName": "Datasource",
                "CommandText": "$.ds_sales.result.*"
            },
            "CaseSensitivity": "Auto",
            "KanatypeSensitivity": "Auto",
            "AccentSensitivity": "Auto",
            "WidthSensitivity": "Auto"
